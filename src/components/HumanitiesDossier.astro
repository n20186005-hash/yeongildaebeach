---
import { getI18n } from '../i18n/ui';
import InfoSection from './InfoSection.astro';
import SitePlaques from './SitePlaques.astro';
import ScienceArt from './ScienceArt.astro';
const { messages } = getI18n(Astro.url);
const h = messages.humanities;
---

<section id="history" class="section-padding" style="background: var(--bg-primary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{h.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{h.subtitle}</p>
    </div>

    <div class="max-w-5xl mx-auto space-y-14">
      <InfoSection embedded />
      <SitePlaques embedded />
      <ScienceArt embedded />
    </div>
  </div>
</section>

