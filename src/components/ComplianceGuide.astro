---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const c = messages.complianceGuide;
const rules = c.rules ?? [];
---

<section id="etiquette" class="section-padding" style="background: var(--bg-secondary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{c.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{c.subtitle}</p>
    </div>

    <div class="max-w-4xl mx-auto space-y-3">
      {rules.map((r) => (
        <details class="group rounded-2xl border overflow-hidden" style="background: var(--bg-tertiary); border-color: var(--border-color);">
          <summary class="flex items-start justify-between gap-4 cursor-pointer list-none p-5 font-semibold" style="color: var(--text-primary);">
            <span class="flex gap-3">
              {r.badge && <span class="shrink-0 text-base" aria-hidden="true">{r.badge}</span>}
              <span>{r.title}</span>
            </span>
            <span class="shrink-0 text-xl transition-transform group-open:rotate-180" style="color: var(--accent);" aria-hidden="true">⌄</span>
          </summary>
          <div class="px-5 pb-5">
            {r.text && <p class="text-base leading-relaxed" style="color: var(--text-secondary);">{r.text}</p>}
            {r.items && (
              <ul class="mt-4 space-y-3 text-sm" style="color: var(--text-secondary);">
                {r.items.map((it) => (
                  <li class="flex gap-3"><span style="color: var(--accent);">•</span><span>{it}</span></li>
                ))}
              </ul>
            )}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
