---
import { getI18n, languagesList, languages } from '../i18n/ui';

const { lang, t, messages } = getI18n(Astro.url);
const h = messages.header;
const common = messages.common;
const currentPath = Astro.url.pathname;

// keep the same page route (e.g. /es/privacy-policy) when switching language
const pageSeg = Astro.url.pathname.split('/').filter(Boolean).slice(1).join('/');
const switchTo = (l: string) => (pageSeg ? `/${l}/${pageSeg}` : `/${l}`);
---

<header class="sticky top-0 z-50 backdrop-blur" style="background: color-mix(in srgb, var(--bg-primary) 85%, transparent); border-bottom: 1px solid var(--border-color);">
  <div class="max-w-6xl mx-auto px-4 min-h-16 py-3 flex items-center justify-between gap-3 md:gap-4">
    <a href={`/${lang}`} class="font-display text-base sm:text-lg font-semibold leading-tight max-w-[11rem] sm:max-w-none" style="color: var(--text-primary);" set:html={h.siteName}></a>

    <nav class="hidden md:flex items-center gap-4 text-sm lg:gap-5" style="color: var(--text-secondary);">
      <a href={`/${lang}`} class="hover:opacity-70" set:html={h.home}></a>
      <a href={`/${lang}#visit`} class="hover:opacity-70" set:html={h.visit}></a>
      <a href={`/${lang}#transport`} class="hover:opacity-70" set:html={h.transport}></a>
      <a href={`/${lang}#lodging`} class="hover:opacity-70" set:html={h.lodging}></a>
      <a href={`/${lang}#history`} class="hover:opacity-70" set:html={h.history}></a>
      <a href={`/${lang}#gallery`} class="hover:opacity-70" set:html={h.gallery}></a>
      <a href={`/${lang}#reviews`} class="hover:opacity-70" set:html={h.reviews}></a>
      <a href={`/${lang}#faq`} class="hover:opacity-70" set:html={h.faq}></a>
      <a href={`/${lang}#map`} class="hover:opacity-70" set:html={h.map}></a>
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <button type="button" id="mobile-menu-toggle" class="md:hidden w-9 h-9 rounded-lg border flex items-center justify-center text-lg" style="border-color: var(--border-color); color: var(--text-primary);" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        ☰
      </button>

      <!-- Language toggle -->
      <div class="relative hidden sm:block">
        <button type="button" class="text-sm px-3 py-1.5 rounded-lg border" style="border-color: var(--border-color); color: var(--text-primary);" onclick="this.nextElementSibling.classList.toggle('hidden')" aria-label={common.changeLanguage}>
          <span set:html={languages[lang]}></span> ▾
        </button>
        <div class="hidden absolute right-0 mt-2 w-40 rounded-xl border bg-[var(--card-bg)] shadow-lg overflow-hidden" style="border-color: var(--border-color);" data-lang-dropdown>
          {languagesList.map((l) => (
            <a href={switchTo(l)} class="block px-4 py-2 text-sm hover:bg-white/10" style="color: var(--text-primary);">
              {languages[l]}
            </a>
          ))}
        </div>
      </div>

      <!-- Theme toggle -->
      <button type="button" id="theme-toggle" class="w-9 h-9 rounded-lg border flex items-center justify-center text-lg" style="border-color: var(--border-color); color: var(--text-primary);" aria-label={common.toggleTheme}>
        🌓
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t px-4 py-4" style="border-color: var(--border-color); background: color-mix(in srgb, var(--bg-primary) 96%, transparent);">
    <nav class="grid grid-cols-2 gap-2 text-sm" style="color: var(--text-secondary);">
      <a href={`/${lang}`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.home}></a>
      <a href={`/${lang}#visit`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.visit}></a>
      <a href={`/${lang}#transport`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.transport}></a>
      <a href={`/${lang}#lodging`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.lodging}></a>
      <a href={`/${lang}#history`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.history}></a>
      <a href={`/${lang}#gallery`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.gallery}></a>
      <a href={`/${lang}#reviews`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.reviews}></a>
      <a href={`/${lang}#faq`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.faq}></a>
      <a href={`/${lang}#map`} class="rounded-lg px-3 py-2 border hover:opacity-80" style="border-color: var(--border-color);" set:html={h.map}></a>
    </nav>

    <div class="mt-4 pt-4 border-t" style="border-color: var(--border-color);">
      <p class="text-xs uppercase tracking-[0.18em] mb-3" style="color: var(--text-muted);">{common.changeLanguage}</p>
      <div class="grid grid-cols-2 gap-2">
        {languagesList.map((l) => (
          <a href={switchTo(l)} class="rounded-lg px-3 py-2 text-sm border hover:opacity-80" style="border-color: var(--border-color); color: var(--text-primary);">
            {languages[l]}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    var menuToggle = document.getElementById('mobile-menu-toggle');
    var mobileMenu = document.getElementById('mobile-menu');
    if (btn) {
      btn.addEventListener('click', function () {
        var root = document.documentElement;
        var isDark = root.getAttribute('data-theme') === 'dark';
        if (isDark) {
          root.removeAttribute('data-theme');
          try { localStorage.setItem('theme', 'light'); } catch (e) {}
        } else {
          root.setAttribute('data-theme', 'dark');
          try { localStorage.setItem('theme', 'dark'); } catch (e) {}
        }
      });
    }
    if (menuToggle && mobileMenu) {
      menuToggle.addEventListener('click', function () {
        var isHidden = mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        menuToggle.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      });
    }
    // close language dropdown on outside click
    document.addEventListener('click', function (e) {
      var dropdowns = document.querySelectorAll('[data-lang-dropdown]');
      dropdowns.forEach(function (dd) {
        if (dd.parentElement && !dd.parentElement.contains(e.target)) {
          dd.classList.add('hidden');
        }
      });
    });
  })();
</script>
