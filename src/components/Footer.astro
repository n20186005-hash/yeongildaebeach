---
import { getI18n } from '../i18n/ui';
const { lang, messages } = getI18n(Astro.url);
const f = messages.footer;
const links = f.officialLinksList;
---

<footer class="section-padding" style="background: var(--bg-tertiary); border-top: 1px solid var(--border-color);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="mission-block mb-10">
      <h3 class="mission-title">🎯 {f.mission.title}</h3>
      <p class="mission-text">{f.mission.text}</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      <div>
        <h3 class="font-display text-xl font-semibold mb-3" style="color: var(--text-primary);" set:html={f.siteName}></h3>
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">{f.rights}</p>
      </div>

      <div>
        <h4 class="font-semibold mb-3" style="color: var(--text-primary);">{f.officialResourcesTitle}</h4>
        <ul class="space-y-2 text-sm">
          {links.map((link) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="hover:opacity-70 break-words" style="color: var(--accent);">
                {link.name} ↗
              </a>
            </li>
          ))}
          <li class="pt-2 border-t" style="border-color: var(--border-color);">
            <a href={f.mapsUrl} target="_blank" rel="noopener noreferrer" class="hover:opacity-70 font-medium" style="color: var(--accent);">
              {f.mapsLabel}
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-3" style="color: var(--text-primary);">{f.legalLinksTitle}</h4>
        <ul class="space-y-2 text-sm">
          <li><a href={`/${lang}/privacy-policy`} class="hover:opacity-70" style="color: var(--text-secondary);">{f.privacy}</a></li>
          <li><a href={`/${lang}/terms-of-service`} class="hover:opacity-70" style="color: var(--text-secondary);">{f.terms}</a></li>
          <li><a href={`/${lang}/cookie-settings`} class="hover:opacity-70" style="color: var(--text-secondary);">{f.cookies}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t text-xs" style="border-color: var(--border-color); color: var(--text-muted);">
      <p class="leading-relaxed" set:html={f.disclaimer}></p>
      {f.dataSourceLabel && f.dataSource && (
        <p class="mt-3 leading-relaxed"><span class="font-medium" style="color: var(--text-secondary);">{f.dataSourceLabel}：</span> <span set:html={f.dataSource}></span></p>
      )}
    </div>
  </div>
</footer>
