---
import { getI18n } from '../i18n/ui';
const { messages } = getI18n(Astro.url);
const r = messages.hiddenRules;
const highlights = r.highlights ?? [];
const panels = r.panels ?? [];
---

<section id="visit" class="section-padding" style="background: var(--bg-primary);">
  <div class="max-w-6xl mx-auto px-4">
    <div class="max-w-3xl mx-auto text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold mb-3" style="color: var(--text-primary);">{r.title}</h2>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--text-secondary);">{r.subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      {highlights.map((h) => (
        <div class="rounded-2xl p-6 border h-full" style="background: var(--card-bg); border-color: var(--border-color); box-shadow: var(--card-shadow);">
          <div class="flex items-start gap-4">
            {h.icon && <span class="text-2xl" aria-hidden="true">{h.icon}</span>}
            <div>
              <p class="text-xs uppercase tracking-[0.18em] mb-1" style="color: var(--text-muted);">{h.label}</p>
              <p class="text-base font-semibold" style="color: var(--text-primary);">{h.value}</p>
              {h.note && <p class="text-sm leading-relaxed mt-2" style="color: var(--text-secondary);">{h.note}</p>}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="max-w-4xl mx-auto space-y-3">
      {panels.map((p) => (
        <details class="group rounded-2xl border overflow-hidden" style="background: var(--bg-tertiary); border-color: var(--border-color);">
          <summary class="flex items-start justify-between gap-4 cursor-pointer list-none p-5 font-semibold" style="color: var(--text-primary);">
            <span>{p.q}</span>
            <span class="shrink-0 text-xl transition-transform group-open:rotate-180" style="color: var(--accent);" aria-hidden="true">⌄</span>
          </summary>
          <div class="px-5 pb-5">
            {p.a && <p class="text-base leading-relaxed" style="color: var(--text-secondary);">{p.a}</p>}
            {p.items && (
              <ul class="mt-4 space-y-3 text-sm" style="color: var(--text-secondary);">
                {p.items.map((it) => (
                  <li class="flex gap-3"><span style="color: var(--accent);">•</span><span>{it}</span></li>
                ))}
              </ul>
            )}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
