---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SectionNav from '../../components/SectionNav.astro';
import Hero from '../../components/Hero.astro';
import QuickFactsDashboard from '../../components/QuickFactsDashboard.astro';
import ComplianceGuide from '../../components/ComplianceGuide.astro';
import HigashiyamaRoute from '../../components/HigashiyamaRoute.astro';
import Intro from '../../components/Intro.astro';
import Transport from '../../components/Transport.astro';
import Lodging from '../../components/Lodging.astro';
import HumanitiesDossier from '../../components/HumanitiesDossier.astro';
import OutdoorMuseum from '../../components/OutdoorMuseum.astro';
import Gallery from '../../components/Gallery.astro';
import FeaturedQuotes from '../../components/FeaturedQuotes.astro';
import HiddenRules from '../../components/HiddenRules.astro';
import Reviews from '../../components/Reviews.astro';
import MapEmbed from '../../components/MapEmbed.astro';
import DeepDive from '../../components/DeepDive.astro';
import FAQ from '../../components/FAQ.astro';
import { getI18n, languagesList } from '../../i18n/ui';

export function getStaticPaths() {
  return languagesList.map((lang) => ({ params: { lang } }));
}

const { messages } = getI18n(Astro.url);
const faq = messages.faq;
const faqLd = (() => {
  const categories = faq?.categories ?? [];
  const mainEntity = categories.flatMap((cat) =>
    (cat.items ?? []).map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  );
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity,
  };
})();
---

<BaseLayout title={messages.meta.title} description={messages.meta.description} path="">
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)}></script>
  <Breadcrumbs />
  <SectionNav />
  <Hero />
  <QuickFactsDashboard />
  <Intro />
  <HumanitiesDossier />
  <DeepDive />
  <Transport />
  <HigashiyamaRoute />
  <HiddenRules />
  <ComplianceGuide />
  <Lodging />
  <MapEmbed />
  <FAQ />
  <OutdoorMuseum />
  <Gallery />
  <FeaturedQuotes />
  <Reviews />
</BaseLayout>
