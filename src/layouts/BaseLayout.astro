---
import '../styles/global.css';
import Header from '../components/Header.astro';
import NoticeBanner from '../components/NoticeBanner.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, buildAlternates, htmlLangAttr, getI18n } from '../i18n/ui';
import { ogLocale, siteConfig } from '../config';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const htmlLang = htmlLangAttr(lang);
const alts = buildAlternates(path);
const canonical = alts[lang] ?? alts.zh;
const { messages } = getI18n(Astro.url);
const hero = messages.hero ?? {};
const accessNote =
  hero.accessNote ??
  'Public beach area is generally accessible throughout the day. Water access and seasonal facilities depend on weather and official operating periods.';
const serviceNote =
  hero.serviceNote ??
  'Lifeguards, showers, and changing facilities operate seasonally and should be confirmed on site.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TouristAttraction',
  name: messages.meta.title,
  description: messages.meta.description,
  url: canonical,
  image: 'https://yeongildaebeach.com/gallery/yeongildaebeach-1.jpg',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '1015 Duho-dong, Buk-gu, Pohang-si',
    addressLocality: 'Pohang-si',
    addressRegion: 'Gyeongsangbuk-do',
    addressCountry: 'KR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 36.0573,
    longitude: 129.3778,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  isAccessibleForFree: true,
  offers: [
    {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'KRW',
      url: canonical,
      description: messages.meta.description,
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.3',
    reviewCount: '7762',
  },
  additionalProperty: [
    {
      '@type': 'PropertyValue',
      name: 'Access',
      value: accessNote,
    },
    {
      '@type': 'PropertyValue',
      name: 'Seasonal services',
      value: serviceNote,
    },
  ],
  sameAs: ['https://maps.app.goo.gl/iGn647PuFKMeiBjcA'],
};
  const breadcrumbLd = (() => {
    const bc = messages.breadcrumb;
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: bc.home, item: `${siteConfig.baseUrl}/${lang}` },
        { '@type': 'ListItem', position: 2, name: bc.region, item: `${siteConfig.baseUrl}/${lang}#overview` },
        { '@type': 'ListItem', position: 3, name: bc.city, item: `${siteConfig.baseUrl}/${lang}#transport` },
        { '@type': 'ListItem', position: 4, name: bc.current, item: canonical },
      ],
    };
  })();
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh" href={alts.zh} />
    <link rel="alternate" hreflang="en" href={alts.en} />
    <link rel="alternate" hreflang="ja" href={alts.ja} />
    <link rel="alternate" hreflang="ko" href={alts.ko} />
    <link rel="alternate" hreflang="x-default" href={alts.xDefault} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={ogLocale[lang] ?? lang} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)}></script>
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)}></script>

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {}
      })();
    </script>

    <slot name="head" />
  </head>
  <body class="min-h-screen">
    <Header />
    <NoticeBanner />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
